@model FINAL.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blooms & Stitch - Register</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body class="register-page">
    <div class="register-wrapper">
        <div class="register-box">
            <h2>Create Account</h2>
            <p class="register-subtitle">Join Blooms & Stitch today</p>

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
            {
                <div class="alert-error">
                    <i class="fas fa-exclamation-circle"></i>
                    @foreach (var error in ViewData.ModelState[""]!.Errors)
                    {
                        <span>@error.ErrorMessage</span>
                    }
                </div>
            }

            <form method="post" action="/Account/Register" novalidate id="registerForm">
                @Html.AntiForgeryToken()

                <!-- Hidden role default since we removed it from UI -->
                <input type="hidden" name="Role" value="Staff" />

                <div class="simple-form-group">
                    <label>Full Name</label>
                    <input type="text" name="FullName"
                           value="@Model?.FullName"
                           placeholder="Enter your full name"
                           class="@(ViewData.ModelState["FullName"]?.Errors.Count > 0 ? "input-error" : "")" />
                    @Html.ValidationMessage("FullName", "", new { @class = "field-error" })
                </div>

                <div class="simple-form-group">
                    <label>Email Address</label>
                    <input type="email" name="Email" id="emailInput"
                           value="@Model?.Email"
                           placeholder="Enter your email"
                           class="@(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "input-error" : "")" />
                    <span class="field-error" id="emailClientError" style="display:none;">
                        Only @@gmail.com email addresses are accepted.
                    </span>
                    @Html.ValidationMessage("Email", "", new { @class = "field-error" })
                </div>

                <div class="simple-form-group">
                    <label>Username</label>
                    <input type="text" name="Username"
                           value="@Model?.Username"
                           placeholder="Choose a username"
                           class="@(ViewData.ModelState["Username"]?.Errors.Count > 0 ? "input-error" : "")" />
                    @Html.ValidationMessage("Username", "", new { @class = "field-error" })
                </div>

                <div class="simple-form-group">
                    <label>Password</label>
                    <div class="password-wrap">
                        <input type="password" name="Password" id="regPassword"
                               placeholder="Min. 8 characters"
                               oninput="checkStrength(this.value)"
                               class="@(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "input-error" : "")" />
                        <button type="button" class="toggle-pw" onclick="togglePassword('regPassword', this)">
                            <i class="far fa-eye"></i>
                        </button>
                    </div>
                    <div class="password-strength">
                        <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
                        <span class="strength-text" id="strengthText"></span>
                    </div>
                    @Html.ValidationMessage("Password", "", new { @class = "field-error" })
                </div>

                <div class="simple-form-group">
                    <label>Confirm Password</label>
                    <div class="password-wrap">
                        <input type="password" name="ConfirmPassword" id="confirmPassword"
                               placeholder="Re-enter your password"
                               oninput="checkMatch()"
                               class="@(ViewData.ModelState["ConfirmPassword"]?.Errors.Count > 0 ? "input-error" : "")" />
                        <button type="button" class="toggle-pw" onclick="togglePassword('confirmPassword', this)">
                            <i class="far fa-eye"></i>
                        </button>
                    </div>
                    <span class="field-error" id="matchError" style="display:none;">
                        Passwords do not match.
                    </span>
                    @Html.ValidationMessage("ConfirmPassword", "", new { @class = "field-error" })
                </div>

                <button type="submit" class="btn-register">Register</button>
            </form>

            <div class="register-switch">
                <a href="#">Terms of Service</a>
            </div>
            <div class="register-switch" style="margin-top:8px;">
                Already have an account? <a href="/Account/Login">Sign in</a>
            </div>
        </div>
    </div>

    <script>
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('i');
            input.type = input.type === 'password' ? 'text' : 'password';
            icon.className = input.type === 'password' ? 'far fa-eye' : 'far fa-eye-slash';
        }

        const emailInput = document.getElementById('emailInput');
            emailInput.addEventListener('blur', function() {
                const emailError = document.getElementById('emailClientError');
                const emailRegex = /^[a-zA-Z0-9._%+\-]+@@gmail\.com$/;
                if (this.value && !emailRegex.test(this.value)) {
                    emailError.style.display = 'block';
                    this.classList.add('input-error');
                } else {
                    emailError.style.display = 'none';
                    this.classList.remove('input-error');
                }
            });

        function checkStrength(val) {
            const fill = document.getElementById('strengthFill');
            const text = document.getElementById('strengthText');
            let score = 0;
            if (val.length >= 8) score++;
            if (val.length >= 12) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/[0-9]/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;
            const levels = [
                { label: '', color: '#e0d5c9', width: '0%' },
                { label: 'Too short', color: '#ef4444', width: '20%' },
                { label: 'Weak', color: '#f97316', width: '40%' },
                { label: 'Fair', color: '#eab308', width: '60%' },
                { label: 'Good', color: '#22c55e', width: '80%' },
                { label: 'Strong', color: '#16a34a', width: '100%' },
            ];
            const level = val.length === 0 ? 0 : Math.min(score, 5);
            fill.style.width = levels[level].width;
            fill.style.background = levels[level].color;
            text.textContent = levels[level].label;
            text.style.color = levels[level].color;
        }

        function checkMatch() {
            const pw = document.getElementById('regPassword').value;
            const cpw = document.getElementById('confirmPassword').value;
            const err = document.getElementById('matchError');
            const confirmInput = document.getElementById('confirmPassword');
            if (cpw && pw !== cpw) {
                err.style.display = 'block';
                confirmInput.classList.add('input-error');
            } else {
                err.style.display = 'none';
                confirmInput.classList.remove('input-error');
            }
        }

        document.getElementById('registerForm').addEventListener('submit', function (e) {
            const pw = document.getElementById('regPassword').value;
            const cpw = document.getElementById('confirmPassword').value;
            const email = document.getElementById('emailInput').value;
            const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            let hasError = false;
            if (pw !== cpw) {
                document.getElementById('matchError').style.display = 'block';
                document.getElementById('confirmPassword').classList.add('input-error');
                hasError = true;
            }
            if (email && !emailRegex.test(email)) {
                document.getElementById('emailClientError').style.display = 'block';
                document.getElementById('emailInput').classList.add('input-error');
                hasError = true;
            }
            if (hasError) e.preventDefault();
        });
    </script>
</body>
</html>
