@model FINAL.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blooms & Stitch - Login</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body>
    <div class="auth-wrapper">

        <!-- Left Panel -->
        <div class="auth-panel-left">
            <div class="brand-mark">
                <div class="brand-icon"><i class="fas fa-seedling"></i></div>
                <div>
                    <h1>Blooms & Stitch</h1>
                    <p>Crochet Flowers</p>
                </div>
            </div>
            <div class="panel-tagline">
                <h2>Welcome back.</h2>
                <p>Sign in to manage your users, orders, and everything in between.</p>
            </div>
            <div class="panel-footer">© 2025 Blooms & Stitch</div>
        </div>

        <!-- Right Panel -->
        <div class="auth-panel-right">
            <h2>Sign In</h2>
            <p class="auth-subtitle">Enter your email or username to continue.</p>

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
            {
                <div class="alert-error">
                    <i class="fas fa-exclamation-circle"></i>
                    @foreach (var error in ViewData.ModelState[""]!.Errors)
                    {
                        <span>@error.ErrorMessage</span>
                    }
                </div>
            }

            <form method="post" action="/Account/Login" novalidate>
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label>Email or Username</label>
                    <div class="input-wrapper">
                        <i class="far fa-user"></i>
                        <input type="text" name="EmailOrUsername"
                               value="@Model?.EmailOrUsername"
                               placeholder="Enter email or username"
                               class="@(ViewData.ModelState["EmailOrUsername"]?.Errors.Count > 0 ? "input-error" : "")" />
                    </div>
                    @Html.ValidationMessage("EmailOrUsername", "", new { @class = "field-error" })
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <div class="input-wrapper">
                        <i class="fas fa-lock"></i>
                        <input type="password" name="Password" id="loginPassword"
                               placeholder="Enter your password"
                               class="@(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "input-error" : "")" />
                        <button type="button" class="toggle-password" onclick="togglePassword('loginPassword', this)">
                            <i class="far fa-eye"></i>
                        </button>
                    </div>
                    @Html.ValidationMessage("Password", "", new { @class = "field-error" })
                </div>

                <div class="checkbox-group" style="margin-bottom:20px;">
                    <input type="checkbox" name="RememberMe" id="rememberMe" value="true" />
                    <label for="rememberMe">Remember me</label>
                </div>

                <button type="submit" class="btn-submit">
                    <i class="fas fa-sign-in-alt" style="margin-right:8px;"></i> Sign In
                </button>
            </form>

            <div class="auth-switch">
                Don't have an account? <a href="/Account/Register">Create one</a>
            </div>
        </div>
    </div>

    <script>
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'far fa-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'far fa-eye';
            }
        }
    </script>
</body>
</html>
