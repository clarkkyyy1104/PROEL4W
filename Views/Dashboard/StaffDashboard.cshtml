@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
    .welcome-banner { background: linear-gradient(135deg, #a8c1a8, #6b8f6b); border-radius: 16px; padding: 28px 32px; margin-bottom: 32px; max-width: 1100px; display: flex; justify-content: space-between; align-items: center; }
    .welcome-banner h2 { font-family: 'Playfair Display', serif; color: white; font-size: 1.5rem; font-weight: 600; margin-bottom: 4px; }
    .welcome-banner p { color: rgba(255,255,255,0.75); font-size: 0.88rem; }
    .welcome-role { background: rgba(255,255,255,0.2); color: white; padding: 6px 16px; border-radius: 20px; font-size: 0.82rem; font-weight: 600; border: 1px solid rgba(255,255,255,0.3); }

    .dashboard-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 18px; max-width: 1100px; margin-bottom: 32px; }
    .stat-card { background: linear-gradient(145deg, #b8c9b8, #9ab09a); border: 1px solid #5a7a5a; border-radius: 14px; padding: 22px 18px; display: flex; flex-direction: column; transition: transform 0.2s; }
    .stat-card:hover { transform: translateY(-3px); }
    .stat-icon { width: 40px; height: 40px; border-radius: 10px; background: rgba(255,255,255,0.25); display: flex; align-items: center; justify-content: center; font-size: 1rem; color: #1a2e1a; margin-bottom: 14px; }
    .stat-value { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 600; color: #1a1a1a; line-height: 1; margin-bottom: 5px; }
    .stat-label { font-size: 0.78rem; color: #2a3a2a; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; }

    .section-title { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: #2e221a; margin-bottom: 14px; font-weight: 600; }
    .quick-links { display: flex; gap: 12px; flex-wrap: wrap; max-width: 1100px; }
    .quick-link { background: #f5efe8; border: 1px solid #c9b9a8; border-radius: 12px; padding: 14px 20px; text-decoration: none; color: #2e221a; display: flex; align-items: center; gap: 10px; font-size: 0.88rem; font-weight: 500; transition: background 0.15s, transform 0.15s; }
    .quick-link:hover { background: #ede0d4; transform: translateY(-2px); }
    .quick-link i { color: #6b8f6b; }

    .view-only-notice { background: #f0f7f0; border: 1px solid #9ab09a; border-radius: 10px; padding: 10px 16px; margin-bottom: 28px; max-width: 1100px; font-size: 0.82rem; color: #3a5a3a; display: flex; align-items: center; gap: 8px; }
</style>
}

<div class="welcome-banner">
    <div>
        <h2>Good day, @ViewBag.CurrentUserName! 🌿</h2>
        <p>Here's your overview for today.</p>
    </div>
    <span class="welcome-role">@ViewBag.CurrentUserRole</span>
</div>

<div class="view-only-notice">
    <i class="fas fa-info-circle"></i>
    You have <strong>view-only</strong> access. Contact an Admin for any changes.
</div>

<p class="section-title">Overview</p>
<div class="dashboard-grid">
    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-receipt"></i></div>
        <div class="stat-value">@ViewBag.TotalOrders</div>
        <div class="stat-label">Total Orders</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-clock"></i></div>
        <div class="stat-value">@ViewBag.PendingOrders</div>
        <div class="stat-label">Pending Orders</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-boxes"></i></div>
        <div class="stat-value">@ViewBag.TotalInventory</div>
        <div class="stat-label">Inventory Items</div>
    </div>
    @if (ViewBag.LowStockCount > 0)
    {
        <div class="stat-card" style="background:linear-gradient(145deg,#f5c6c6,#e8a0a0);border-color:#c05050;">
            <div class="stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
            <div class="stat-value">@ViewBag.LowStockCount</div>
            <div class="stat-label">Low Stock Items</div>
        </div>
    }
</div>

<p class="section-title">Quick Access</p>
<div class="quick-links">
    <a href="/Order/Index" class="quick-link"><i class="fas fa-receipt"></i> View Orders</a>
    <a href="/Inventory/Index" class="quick-link"><i class="fas fa-boxes"></i> View Inventory</a>
    <a href="/Notification/Index" class="quick-link"><i class="far fa-bell"></i> View Notifications</a>
</div>
