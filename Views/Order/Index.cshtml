@model IEnumerable<FINAL.Models.Order>
@{
    ViewData["Title"] = "Order Management";
    ViewData["ActivePage"] = "Order";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/order.css" />
}

<header class="page-header">
    <h1>Order Management</h1>
    @if (ViewBag.IsAdmin == true)
    {
        <button class="btn-add" onclick="openAddModal()">
            <i class="fas fa-plus"></i> New Order
        </button>
    }
</header>

<div class="orders-table-wrapper">
    <div class="table-toolbar">
        <span class="order-count">@Model.Count() order(s) total</span>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fas fa-receipt"></i>
            <p>No orders yet. Create your first order!</p>
        </div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Customer</th>
                    <th>Product / Item</th>
                    <th>Status</th>
                    <th>Order Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td class="order-id">#@order.Id.ToString("D4")</td>
                        <td class="customer-cell">@order.CustomerName</td>
                        <td class="product-cell">@order.Product</td>
                        <td><span class="status-pill @order.Status.ToLower()">@order.Status</span></td>
                        <td class="date-cell">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                        <td>
                            @if (ViewBag.IsAdmin == true)
                            {
                                <div class="action-btns">
                                    <button onclick="openEditModal(@order.Id, '@order.CustomerName', '@order.Product', '@order.Status')">
                                        <i class="far fa-edit"></i> Edit
                                    </button>
                                    <button class="delete-btn" onclick="openDeleteModal(@order.Id, '@order.CustomerName')">
                                        <i class="far fa-trash-alt"></i> Delete
                                    </button>
                                </div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- ADD ORDER MODAL -->
<div class="modal-overlay" id="addModal">
    <div class="modal-box">
        <h2>New Order</h2>
        <form method="post" action="/Order/Create">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Customer Name</label>
                <input type="text" name="CustomerName" placeholder="e.g. Maria Santos" required />
            </div>
            <div class="form-group">
                <label>Product / Item</label>
                <input type="text" name="Product" placeholder="e.g. Crochet Rose Bouquet" required />
            </div>
            <div class="form-group">
                <label>Status</label>
                <select name="Status">
                    <option value="Pending">Pending</option>
                    <option value="Completed">Completed</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal('addModal')">Cancel</button>
                <button type="submit" class="btn btn-primary"><i class="fas fa-plus"></i> Create Order</button>
            </div>
        </form>
    </div>
</div>

<!-- EDIT ORDER MODAL -->
<div class="modal-overlay" id="editModal">
    <div class="modal-box">
        <h2>Edit Order</h2>
        <form method="post" id="editForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="editId" />
            <div class="form-group">
                <label>Customer Name</label>
                <input type="text" name="CustomerName" id="editCustomer" required />
            </div>
            <div class="form-group">
                <label>Product / Item</label>
                <input type="text" name="Product" id="editProduct" required />
            </div>
            <div class="form-group">
                <label>Status</label>
                <select name="Status" id="editStatus">
                    <option value="Pending">Pending</option>
                    <option value="Completed">Completed</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal('editModal')">Cancel</button>
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- DELETE CONFIRM MODAL -->
<div class="modal-overlay" id="deleteModal">
    <div class="modal-box" style="text-align:center;">
        <h2 style="margin-bottom:12px;">Delete Order</h2>
        <p style="color:#6b5a4e; margin-bottom:28px;">
            Are you sure you want to delete the order from <strong id="deleteOrderCustomer"></strong>? This cannot be undone.
        </p>
        <form method="post" id="deleteForm">
            @Html.AntiForgeryToken()
            <div class="modal-actions" style="justify-content:center;">
                <button type="button" class="btn btn-secondary" onclick="closeModal('deleteModal')">Cancel</button>
                <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Delete</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function openAddModal() { document.getElementById('addModal').classList.add('open'); }
    function openEditModal(id, customer, product, status) {
        document.getElementById('editId').value = id;
        document.getElementById('editCustomer').value = customer;
        document.getElementById('editProduct').value = product;
        document.getElementById('editStatus').value = status;
        document.getElementById('editForm').action = '/Order/Edit/' + id;
        document.getElementById('editModal').classList.add('open');
    }
    function openDeleteModal(id, customer) {
        document.getElementById('deleteOrderCustomer').textContent = customer;
        document.getElementById('deleteForm').action = '/Order/Delete/' + id;
        document.getElementById('deleteModal').classList.add('open');
    }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }
    document.querySelectorAll('.modal-overlay').forEach(overlay => {
        overlay.addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('open');
        });
    });
</script>
}
