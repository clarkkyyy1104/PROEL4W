@model IEnumerable<FINAL.Models.InventoryItem>
@{
    ViewData["Title"] = "Inventory Management";
    ViewData["ActivePage"] = "Inventory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/inventory.css" />
}

<header class="page-header">
    <h1>Inventory Management</h1>
    @if (ViewBag.IsAdmin == true)
    {
        <button class="btn-add" onclick="openAddModal()">
            <i class="fas fa-plus"></i> Add Item
        </button>
    }
</header>

<!-- Search Bar -->
<form method="get" action="/Inventory/Index" class="search-form">
    <div class="search-wrapper">
        <i class="fas fa-search"></i>
        <input type="text" name="search" value="@ViewBag.Search" placeholder="Search..." class="search-input" />
    </div>
</form>

<!-- Table -->
<div class="inv-table-wrapper">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fas fa-boxes"></i>
            <p>No inventory items found. Add your first item!</p>
        </div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Item Name</th>
                    <th>Quantity</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.Quantity <= 5 ? "low-stock" : "")">
                        <td class="item-name-cell">
                            @item.ItemName
                            @if (item.Quantity <= 5)
                            {
                                <span class="low-stock-badge">Low Stock</span>
                            }
                        </td>
                        <td class="qty-cell">@item.Quantity</td>
                        <td class="cat-cell">@item.Category</td>
                        <td class="price-cell">₱@item.Price.ToString("N2")</td>
                        <td>
                            <div class="action-btns">
                                <button class="btn-edit" onclick="openEditModal(@item.Id, '@item.ItemName.Replace("'", "\\'")', @item.Quantity, '@item.Category', @item.Price, '@item.Description.Replace("'", "\\'")')">
                                    Edit
                                </button>
                                <button class="btn-delete-icon" onclick="openDeleteModal(@item.Id, '@item.ItemName.Replace("'", "\\'")') ">
                                    <i class="far fa-trash-alt"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- ADD MODAL -->
<div class="modal-overlay" id="addModal">
    <div class="modal-box">
        <h2>Add New Item</h2>
        <form method="post" action="/Inventory/Create">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Item Name</label>
                <input type="text" name="ItemName" placeholder="e.g. Rose Bloom Crochet" required />
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Price (₱)</label>
                    <input type="number" name="Price" min="0" step="0.01" placeholder="0.00" required />
                </div>
            </div>
            <div class="form-group">
                <label>Category</label>
                <select name="Category" required>
                    <option value="">-- Select Category --</option>
                    <option value="Hair Accessories">Hair Accessories</option>
                    <option value="Keychain">Keychain</option>
                    <option value="Home Decor">Home Decor</option>
                    <option value="Bouquet">Bouquet</option>
                    <option value="Sachet / Fragrance Holder">Sachet / Fragrance Holder</option>
                    <option value="Wall Hanging">Wall Hanging</option>
                    <option value="Brooch / Pin">Brooch / Pin</option>
                    <option value="Bag Charm">Bag Charm</option>
                </select>
            </div>
            <div class="form-group">
                <label>Description <span style="color:#aaa;font-weight:400;">(optional)</span></label>
                <textarea name="Description" rows="3" placeholder="Short description..."></textarea>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal('addModal')">Cancel</button>
                <button type="submit" class="btn btn-primary"><i class="fas fa-plus"></i> Add Item</button>
            </div>
        </form>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal-overlay" id="editModal">
    <div class="modal-box">
        <h2>Edit Item</h2>
        <form method="post" id="editForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="editId" />
            <div class="form-group">
                <label>Item Name</label>
                <input type="text" name="ItemName" id="editName" required />
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Quantity</label>
                    <input type="number" name="Quantity" id="editQty" min="0" required />
                </div>
                <div class="form-group">
                    <label>Price (₱)</label>
                    <input type="number" name="Price" id="editPrice" min="0" step="0.01" required />
                </div>
            </div>
            <div class="form-group">
                <label>Category</label>
                <select name="Category" id="editCategory" required>
                    <option value="Hair Accessories">Hair Accessories</option>
                    <option value="Keychain">Keychain</option>
                    <option value="Home Decor">Home Decor</option>
                    <option value="Bouquet">Bouquet</option>
                    <option value="Sachet / Fragrance Holder">Sachet / Fragrance Holder</option>
                    <option value="Wall Hanging">Wall Hanging</option>
                    <option value="Brooch / Pin">Brooch / Pin</option>
                    <option value="Bag Charm">Bag Charm</option>
                </select>
            </div>
            <div class="form-group">
                <label>Description <span style="color:#aaa;font-weight:400;">(optional)</span></label>
                <textarea name="Description" id="editDesc" rows="3"></textarea>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal('editModal')">Cancel</button>
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal-overlay" id="deleteModal">
    <div class="modal-box" style="text-align:center;">
        <h2 style="margin-bottom:12px;">Delete Item</h2>
        <p style="color:#6b5a4e; margin-bottom:28px;">
            Are you sure you want to delete <strong id="deleteItemName"></strong>? This cannot be undone.
        </p>
        <form method="post" id="deleteForm">
            @Html.AntiForgeryToken()
            <div class="modal-actions" style="justify-content:center;">
                <button type="button" class="btn btn-secondary" onclick="closeModal('deleteModal')">Cancel</button>
                <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Delete</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function openAddModal() { document.getElementById('addModal').classList.add('open'); }

    function openEditModal(id, name, qty, category, price, desc) {
        document.getElementById('editId').value = id;
        document.getElementById('editName').value = name;
        document.getElementById('editQty').value = qty;
        document.getElementById('editCategory').value = category;
        document.getElementById('editPrice').value = price;
        document.getElementById('editDesc').value = desc;
        document.getElementById('editForm').action = '/Inventory/Edit/' + id;
        document.getElementById('editModal').classList.add('open');
    }

    function openDeleteModal(id, name) {
        document.getElementById('deleteItemName').textContent = name;
        document.getElementById('deleteForm').action = '/Inventory/Delete/' + id;
        document.getElementById('deleteModal').classList.add('open');
    }

    function closeModal(id) { document.getElementById(id).classList.remove('open'); }

    document.querySelectorAll('.modal-overlay').forEach(overlay => {
        overlay.addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('open');
        });
    });
</script>
}
